# Simpler Smart Calendar — example environment.
# Copy to `.env` and fill in. Never commit the real `.env`.

# --- Flask ---
# Secret key for session signing. GENERATE A RANDOM VALUE in production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Single shared password gating /login (there is no user-account model).
APP_PASSWORD=admin

# development | production
FLASK_ENV=production

# --- Hermes agent integration (PRD 002; both optional) ---
# Bearer token for machine clients (the simpler-mcp sidecar). Unset = the
# bearer auth path is off entirely. Generate with: openssl rand -hex 32
API_TOKEN=

# URL of a deployed hermes-webui (https://github.com/nesquena/hermes-webui)
# to embed as the in-app Hermes destination (6th tab, shortcut 6). Unset =
# the tab is hidden. Serve it on a sibling subdomain behind a reverse proxy
# that sets `Content-Security-Policy: frame-ancestors <this app's origin>`
# (see .opencode/plans/002_PRD_hermes-agent-integration.md §4.2).
HERMES_WEBUI_URL=

# --- AI provider (used for task parsing + note Cleanify) ---
# Any OpenAI-compatible endpoint (OpenAI, Mistral, Infomaniak) OR Anthropic.
# Provider is auto-selected by AI_API_BASE_URL heuristics in src/ai_parser.py.
AI_API_KEY=

# Examples:
#   OpenAI:        https://api.openai.com/v1/
#   Mistral:       https://api.mistral.ai/v1/
#   Infomaniak:    https://api.ai.infomaniak.com/v1/
#   Anthropic:     https://api.anthropic.com/   (selects AnthropicProvider)
AI_API_BASE_URL=https://api.openai.com/v1/

# Examples: gpt-3.5-turbo, mistral-small, claude-haiku-4-5, llama-3.1-8b-instruct
AI_MODEL=gpt-3.5-turbo
