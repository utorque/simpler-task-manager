# Simpler Smart Calendar — example environment.
# Copy to `.env` and fill in. Never commit the real `.env`.

# --- Flask ---
# Secret key for session signing. GENERATE A RANDOM VALUE in production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Single shared password gating /login (there is no user-account model).
APP_PASSWORD=admin

# development | production
FLASK_ENV=production

# --- Machine clients ---
# Bearer token for machine clients (the simpler-mcp sidecar and the embedded
# assistant's workspace tools). Unset = the bearer auth path is off entirely
# and the assistant loses its Simpler integration. Generate with:
#   openssl rand -hex 32
API_TOKEN=

# --- Assistant (embedded Chainlit chat, tab 6) ---
# The assistant shares the AI_* provider config below. All knobs optional:
#
# Models offered in the assistant's model picker (comma-separated; first =
# default). Unset -> just AI_MODEL.
#CHAT_MODELS=claude-sonnet-5,claude-haiku-4-5
#
# Max tokens per assistant reply (default 4096).
#CHAT_MAX_TOKENS=4096
#
# JWT secret for the assistant's session tokens. Derived from SECRET_KEY
# when unset — set explicitly only to rotate it independently.
#CHAINLIT_AUTH_SECRET=
#
# Simpler's MCP sidecar, pre-integrated as the assistant's workspace tool
# server. docker-compose sets this on the web service already; set it here
# only for non-compose runs (e.g. a locally running mcp_server):
#SIMPLER_MCP_URL=http://127.0.0.1:8765/mcp
#
# Extra pre-integrated MCP servers (streamable HTTP), name=url pairs:
#CHAT_MCP_SERVERS=weather=https://example.com/mcp
#
# Max tool-call rounds per assistant turn (default 8).
#CHAT_MAX_TOOL_ROUNDS=8
#
# Where the assistant stores uploaded/produced files
# (default: instance/assistant_files; compose points it at the volume
# shared with the sandbox).
#CHAT_FILES_DIR=
#
# Execution sandbox (dockerized MCP sidecar; compose wires
# http://sandbox:8766/mcp). For non-compose dev either run sandbox/server.py
# yourself and set the URL, or set CHAT_LOCAL_SANDBOX=1 to run the same
# tools in-process WITHOUT isolation (dev only).
#SANDBOX_MCP_URL=http://127.0.0.1:8766/mcp
#CHAT_LOCAL_SANDBOX=0
#
# Set to 0 to remove the assistant's web_search/fetch_url tools.
#CHAT_WEB_TOOLS=1

# --- AI provider (used for task parsing + note Cleanify) ---
# Any OpenAI-compatible endpoint (OpenAI, Mistral, Infomaniak) OR Anthropic.
# Provider is auto-selected by AI_API_BASE_URL heuristics in src/ai_parser.py.
AI_API_KEY=

# Examples:
#   OpenAI:        https://api.openai.com/v1/
#   Mistral:       https://api.mistral.ai/v1/
#   Infomaniak:    https://api.ai.infomaniak.com/v1/
#   Anthropic:     https://api.anthropic.com/   (selects AnthropicProvider)
AI_API_BASE_URL=https://api.openai.com/v1/

# Examples: gpt-3.5-turbo, mistral-small, claude-haiku-4-5, llama-3.1-8b-instruct
AI_MODEL=gpt-3.5-turbo
